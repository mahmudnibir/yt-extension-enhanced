{
  "manifest_version": 3,
  "name": "YouTube Playback Enhancer",
  "version": "2.0.1",
  "description": "Set playback speed, auto skip ads, and control YouTube content visibility",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["*://www.youtube.com/*"],
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "youtube.png"
  },
  "icons": {
    "16": "youtube.png",
    "48": "youtube.png",
    "128": "youtube.png"
  }
}
