{
  "manifest_version": 3,
  "name": "YouTube Enhanced - Speed Control & Bookmarks",
  "version": "3.7.0",
  "description": "Advanced YouTube player with cloud-synced bookmarks, custom speed control, ad skipping, content filters, watch statistics, and full keyboard customization for power users.",
  "author": "Mahmud Nibir",
  "homepage_url": "https://github.com/mahmudnibir/yt-extension-enhanced",
  "permissions": ["storage", "activeTab", "scripting", "tabs"],
  "host_permissions": ["*://www.youtube.com/*", "<all_urls>"],
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["video-hover.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "youtube.png"
  },
  "icons": {
    "16": "youtube.png",
    "48": "youtube.png",
    "128": "youtube.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
